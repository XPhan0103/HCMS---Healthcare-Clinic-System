          style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="290" y="390" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- UC-04 -->
        <mxCell id="p1_uc04"
          value="&lt;b&gt;UC-04&lt;/b&gt;&lt;br/&gt;View Clinical Notes &amp; Prescriptions"
          style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="290" y="520" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- ─ FEATURE LABELS (inside boundary, right column) ─ -->
        <mxCell id="p1_feat1"
          value="«feature»&lt;br/&gt;&lt;b&gt;Self-Service Booking Portal&lt;/b&gt;"
          style="text;html=1;fillColor=#EBF3FB;strokeColor=#6c8ebf;align=center;verticalAlign=middle;fontSize=10;fontStyle=2;rounded=1;arcSize=10;"
          vertex="1" parent="1">
