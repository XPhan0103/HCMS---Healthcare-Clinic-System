<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.0.3 Chrome/140.0.7339.249 Electron/38.7.0 Safari/537.36" version="29.0.3" pages="3">

  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <!-- PAGE 1 | Use Case Diagram: Parents (Phụ huynh)                        -->
  <!-- UCs: UC-01 Book Appointment  UC-02 Patient Demographics               -->
  <!--      UC-03 Receive Confirmation  UC-04 View Clinical Notes            -->
  <!-- ═══════════════════════════════════════════════════════════════════════ -->
  <diagram id="uc_parents" name="UC-01~04: Parents">
    <mxGraphModel dx="1200" dy="820" grid="0" gridSize="10" guides="1"
                  tooltips="1" connect="1" arrows="1" fold="1" page="1"
                  pageScale="1" pageWidth="1100" pageHeight="680" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ─ TITLE ─ -->
        <mxCell id="p1_title"
          value="HCMS — Use Case Diagram  |  Actor: Parents (Phụ huynh)"
          style="text;html=1;fillColor=#0f172a;strokeColor=#0f172a;fontColor=#ffffff;fontStyle=1;fontSize=13;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="30" y="15" width="1020" height="36" as="geometry"/>
        </mxCell>

        <!-- ─ SYSTEM BOUNDARY ─ -->
        <mxCell id="p1_sys"
          value="&lt;b&gt;HCMS System&lt;br/&gt;&lt;/b&gt;&lt;i style=&quot;font-weight:normal;font-size:10px;&quot;&gt;Healthcare Clinic Management System — Pediatrics MVP&lt;/i&gt;"
          style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#1B3A5C;strokeWidth=2;
                 verticalAlign=top;fontStyle=1;fontSize=13;align=center;spacingTop=6;"
          vertex="1" parent="1">
          <mxGeometry x="220" y="60" width="620" height="550" as="geometry"/>
        </mxCell>

        <!-- ─ ACTOR: Parents ─ -->
        <mxCell id="p1_actor"
          value="&lt;b&gt;Parents&lt;/b&gt;&lt;br/&gt;(Phụ huynh)"
          style="shape=mxgraph.uml.actor;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=11;fontStyle=1;verticalLabelPosition=bottom;verticalAlign=top;align=center;"
          vertex="1" parent="1">
          <mxGeometry x="60" y="270" width="60" height="90" as="geometry"/>
        </mxCell>

        <!-- ─ USE CASES (ellipses inside system boundary) ─ -->

        <!-- UC-01 -->
        <mxCell id="p1_uc01"
          value="&lt;b&gt;UC-01&lt;/b&gt;&lt;br/&gt;Book Appointment Online"
          style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=11;align=center;verticalAlign=middle;"
          vertex="1" parent="1">
          <mxGeometry x="290" y="110" width="220" height="70" as="geometry"/>
        </mxCell>

        <!-- UC-02 -->
        <mxCell id="p1_uc02"
          value="&lt;b&gt;UC-02&lt;/b&gt;&lt;br/&gt;Provide Patient Demographics"
