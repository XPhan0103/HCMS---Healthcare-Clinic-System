          vertex="1" parent="1">
          <mxGeometry x="555" y="530" width="245" height="45" as="geometry"/>
        </mxCell>

        <!-- ─ UC DESCRIPTION NOTES ─ -->
        <mxCell id="p1_note01"
          value="Select Doctor &amp; time slot.&lt;br/&gt;System creates APPOINTMENT (Pending)"
