          vertex="1" parent="1">
          <mxGeometry x="555" y="580" width="245" height="32" as="geometry"/>
        </mxCell>

        <!-- ─ ASSOCIATIONS: Actor → Use Cases ─ -->
        <mxCell id="p1_e01" value=""
          style="endArrow=none;html=1;strokeColor=#555555;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" parent="1" source="p1_actor" target="p1_uc01">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p1_e02" value=""
          style="endArrow=none;html=1;strokeColor=#555555;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" parent="1" source="p1_actor" target="p1_uc02">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p1_e03" value=""
          style="endArrow=none;html=1;strokeColor=#555555;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" parent="1" source="p1_actor" target="p1_uc03">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="p1_e04" value=""
          style="endArrow=none;html=1;strokeColor=#555555;strokeWidth=1.5;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" parent="1" source="p1_actor" target="p1_uc04">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- UC-01 includes UC-02 (dashed include arrow) -->
        <mxCell id="p1_inc01" value="«include»"
          style="dashed=1;endArrow=open;endFill=0;html=1;strokeColor=#6c8ebf;fontStyle=3;fontSize=9;align=center;startArrow=none;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;"
          edge="1" parent="1" source="p1_uc01" target="p1_uc02">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Feature connector lines -->
        <mxCell id="p1_fc1" value=""
          style="endArrow=none;html=1;strokeColor=#6c8ebf;strokeWidth=1;dashed=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;"
          edge="1" parent="1" source="p1_uc01" target="p1_feat1">
