        </mxCell>
        <mxCell id="c_l2lbl" value="&lt;b&gt;Receptionist&lt;/b&gt;&lt;br/&gt;(Lễ tân)" style="text;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=center;verticalAlign=middle;fontSize=11;fontStyle=1;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="20" y="260" width="120" height="200" as="geometry"/>
        </mxCell>

        <!-- === PROCESS SHAPES === -->

