        <mxCell id="c_s1" value="Bác sĩ hoàn tất VISIT &amp; PRESCRIPTION&lt;br/&gt;(Trigger tự động từ Hệ thống)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=15;fillColor=#ffffff;strokeColor=#6c8ebf;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="215" y="132" width="190" height="55" as="geometry"/>
        </mxCell>

        <!-- c2: Auto-create BILLING (HCMS) -->
        <mxCell id="c_s2" value="Tự động khởi tạo Hóa đơn BILLING&lt;br/&gt;(Phí Dịch vụ + Danh mục Thuốc)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=15;fillColor=#ffffff;strokeColor=#6c8ebf;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="132" width="190" height="55" as="geometry"/>
        </mxCell>

