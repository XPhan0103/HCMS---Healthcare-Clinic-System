        <mxCell id="c_s3" value="Kiểm tra Hóa đơn BILLING&lt;br/&gt;trên Receptionist Dashboard" style="rounded=1;whiteSpace=wrap;html=1;arcSize=15;fillColor=#ffffff;strokeColor=#d79b00;strokeWidth=2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="440" y="332" width="190" height="55" as="geometry"/>
